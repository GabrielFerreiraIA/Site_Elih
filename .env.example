# ──────────────────────────────────────────────────────────────────────────────
# Elih Seguros — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local com segredos reais.
# ──────────────────────────────────────────────────────────────────────────────

# ── N8N ───────────────────────────────────────────────────────────────────────
# URL do webhook de leads no N8N.
# Padrão já embutido no código, mas prefira definir explicitamente em produção.
N8N_WEBHOOK_URL=https://automacoes-n8n.o1ltcv.easypanel.host/webhook/leads

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL do projeto Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Service Role Key (PRIVADA — nunca exponha no cliente/frontend)
# Encontre em: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Next.js (opcionais) ───────────────────────────────────────────────────────
# Defina apenas se quiser sobrescrever a URL pública (ex: domínio customizado na Vercel)
# NEXT_PUBLIC_SITE_URL=https://www.elih.com.br
